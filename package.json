{
  "name": "tree-sitter-evie",
  "version": "0.1.0",
  "description": "Support for the Evie programming language.",
  "languages": {
    "evie": {
      "name": "Evie",
      "path": ".",
      "matcher": {
        "path_suffixes": [
          "ev"
        ]
      }
    }
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tree-sitter/tree-sitter-evie.git"
  },
  "funding": "",
  "license": "MIT",
  "author": {
    "name": "Hassan",
    "email": "mail@hxkhan.dev",
    "url": ""
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "evie"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.8"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tree-sitter build",
    "generate": "tree-sitter generate",
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}