{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "evie",
      "camelcase": "Evie",
      "title": "Evie",
      "scope": "source.evie",
      "file-types": ["ev"],
      "injection-regex": "^evie$",
      "class-name": "TreeSitterEvie"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Support for the Evie programming language.",
    "authors": [
      {
        "name": "Hassan",
        "email": "mail@hxkhan.dev",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/hxkhan/tree-sitter-evie",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
